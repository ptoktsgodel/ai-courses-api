# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source files
*.cs     text eol=lf
*.csproj text eol=lf
*.sln    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.xml    text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.sh     text eol=lf

# Binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.db     binary
*.dll    binary
*.exe    binary
*.pdb    binary
